rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Dashboard subcollection
      match /dashboard/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Events - readable by everyone, writable by authenticated users
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin replies - readable by authenticated users (filtered by email in app code)
    match /admin_replies/{replyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Contact messages - anyone can create (for guests), only authenticated users can read/update/delete
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Submitted events for approval
    match /submitted_events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
